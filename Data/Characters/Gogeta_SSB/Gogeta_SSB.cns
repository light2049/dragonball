; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------

[Statedef -3]


[State 0]
type = Explod
triggerall = life > 0
triggerall = power>50
trigger1 = timemod = 8,0
anim = 1245
pos = 0-random%25+random%25,-12-random%12+random%26
velocity = 0-random%3+random%3,-3
postype = p1  ;p2,front,back,left,right
removetime = -2
ontop = 1
scale = 0.11,0.11
supermove = 1

[State 0]
type = Explod
triggerall = life > 0
TRIGGERALL = POWER>1800
trigger1 = timemod = 5,0
anim = 1245
pos = 0-random%30+random%30,-13-random%5+random%20
velocity = 0-random%5+random%5,-2
postype = p1  ;p2,front,back,left,right
removetime = -2
ontop = 1
scale = 0.20,0.20
supermove = 1


;This controller plays a sound everytime the player lands from a jump, or
;from a back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = s0,8
