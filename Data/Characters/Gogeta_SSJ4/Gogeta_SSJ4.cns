[Statedef 190]
type = S
ctrl = 0
anim = 190
velset = 0,0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 31
value = S10,1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 6
value = S10,8

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 5
value = S0,9

[State 0, Explod]
type = Explod
trigger1 = TIMEMOD = 3,0
anim = 1224
ID = 1224
pos = -30+random%55,10-random%65
postype = p1  ;p2,front,back,left,right
facing = 1
vfacing = 1
bindtime = 1
vel = 0,-3
accel = 0,0
random = 0,0
removetime = -2
supermove = 1
pausemove = 1
scale = 0.43,0.43
sprpriority = 5

[State 190, 1] ;Freeze animation until PreIntro is over
type = ChangeAnim
trigger1 = RoundState = 0
value = 190

[State 190, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 190, 4] ;Change to stand state
type = ChangeState
trigger1 = AnimTime = 0
value = 0

