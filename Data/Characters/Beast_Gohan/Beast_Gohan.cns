;---------------------------------------------------------------------------
; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------

[Statedef -3]
[state -3];�Ď�
type=varset
triggerall=!ishelper
trigger1=1
var(18)=gametime*5
ignorehitpause=1

[State 0]
type = Explod
triggerall = life > 0
trigger1 = timemod = 8,0
anim = 1225
pos = 0-random%20+random%20,-13-random%5+random%20
velocity = 0-random%2+random%2,-2
postype = p1  ;p2,front,back,left,right
removetime = -2
ontop = 1
scale = 0.28,0.28
supermove = 1

[State 0]
type = Explod
triggerall = life > 0
TRIGGERALL = POWER>1400
trigger1 = timemod = 5,0
anim = 1225
pos = 0-random%20+random%20,-13-random%5+random%20
velocity = 0-random%2+random%2,-2
postype = p1  ;p2,front,back,left,right
removetime = -2
ontop = 1
scale = 0.28,0.28
supermove = 1

;This controller plays a sound everytime the player lands from a jump, or
;from a back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = s0,8
