; Lose by Time Over
; CNS difficulty: basic
[Statedef 170]
type = S
ctrl = 0
anim = 170
velset = 0,0

[State 0, Explod]
type = Explod
trigger1 = animelem = 2
anim = 1229
ID = 1229
pos = 0,-15
postype = p1  ;p2,front,back,left,right
facing = 1
vfacing = 1
bindtime = 1
vel = 0,0
accel = 0,0
random = 0,0
removetime = -2
supermove
pausemove
scale = 1,1
sprpriority = 45


[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 2
value = S0,9

[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

